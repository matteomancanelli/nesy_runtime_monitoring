# Keep the build context small and the image clean.
.git
.gitignore
.claude
.vscode
.pytest_cache
.ruff_cache
**/__pycache__
*.egg-info

# Heavy / irrelevant to running the experiments.
papers*
latex
docs
CLAUDE.md

# Results are produced at run time and mounted from the host as a volume,
# so they must NOT be baked into the image (that would defeat resume).
results
